{
  "name": "propaganistas/browsershot-lambda",
  "conflict": {
    "wnx/sidecar-browsershot": "*"
  },
  "require": {
    "php": "^8.4",
    "aws/aws-sdk-php": "^3.368.0",
    "illuminate/config": "^12.0|^13.0",
    "illuminate/container": "^12.0|^13.0",
    "illuminate/filesystem": "^12.0|^13.0",
    "illuminate/support": "^12.0|^13.0",
    "spatie/laravel-pdf": "^2.4.0",
    "spatie/browsershot": "^5.2.3"
  },
  "autoload": {
    "psr-4": {
      "Propaganistas\\BrowsershotLambda\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Propaganistas\\BrowsershotLambda\\BrowsershotLambdaServiceProvider"
      ]
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
